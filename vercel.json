{
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/build/preview/(.*)",
      "has": [{ "type": "host", "value": "preview.lumine.app" }],
      "destination": "https://api.twinkle.network/build/preview/$1"
    },
    {
      "source": "/build/preview/(.*)",
      "has": [
        {
          "type": "host",
          "value": "^b-[0-9]+\\.preview\\.lumine\\.app$"
        }
      ],
      "destination": "https://api.twinkle.network/build/preview/$1"
    },
    {
      "source": "/build/vendor/(.*)",
      "destination": "https://api.twinkle.network/build/vendor/$1"
    },
    { "source": "/((?!assets/).*)", "destination": "/" }
  ]
}
