{
  "rewrites": [
    {
      "source": "/build/preview/(.*)",
      "has": [{ "type": "host", "value": "preview.lumine.app" }],
      "destination": "https://api.twinkle.network/build/preview/$1"
    },
    {
      "source": "/build/preview/(.*)",
      "has": [
        {
          "type": "host",
          "value": "^b-[0-9]+\\.preview\\.lumine\\.app$"
        }
      ],
      "destination": "https://api.twinkle.network/build/preview/$1"
    },
    { "source": "/(.*)", "destination": "/" }
  ]
}
